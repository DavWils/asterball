extends Resource

class_name TeamResource

## Name of the team.
@export var team_name: String

## Primary color of the team. Will usually be the one that sticks out the most.
@export var primary_color: Color

## Secondary color of the team. Will usually be the more dull color, more prominent on armor.
@export var secondary_color: Color

## Icon for the team.
@export var team_icon: Texture2D
